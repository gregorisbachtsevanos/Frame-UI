{
  "name": "frame-ui",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r build && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=22 <24"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12",
      "@storybook/*": "8.6.18",
      "storybook": "8.6.18"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@storybook/react-vite": "8.6.18",
    "storybook": "8.6.18",
    "turbo": "^2.0.0",
    "typescript": "^5.8.3",
    "vite": "6.4.2"
  }
}
